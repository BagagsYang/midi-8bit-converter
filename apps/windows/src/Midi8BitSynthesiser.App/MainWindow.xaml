<Window
    x:Class="Midi8BitSynthesiser.App.MainWindow"
    x:Name="WindowRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:Midi8BitSynthesiser.App.Converters"
    xmlns:viewModels="using:Midi8BitSynthesiser.App.ViewModels"
    mc:Ignorable="d">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </Window.Resources>

    <Grid
        AllowDrop="True"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
        DragOver="RootGrid_DragOver"
        Drop="RootGrid_Drop">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Margin="16"
            Padding="16"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="20">
            <Grid RowDefinitions="Auto,*,Auto">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="Queue" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Add or drop MIDI files, then export a WAV batch." TextWrapping="WrapWholeWords" />
                    <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.QueueSummary, Mode=OneWay}" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,16,0,16">
                    <Border
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="16"
                        Visibility="{x:Bind ViewModel.HasQueue, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                        <TextBlock Text="" />
                    </Border>

                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12"
                        Visibility="{x:Bind ViewModel.ShowEmptyQueueState, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Drop MIDI Files Here" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Supports .mid and .midi files." />
                    </StackPanel>

                    <ListView
                        x:Name="QueueListView"
                        AllowDrop="True"
                        CanDragItems="True"
                        CanReorderItems="True"
                        ItemsSource="{x:Bind ViewModel.Queue, Mode=OneWay}"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:ConversionJobViewModel">
                                <Border Margin="0,0,0,8" Padding="12" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="14">
                                    <StackPanel Spacing="10">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind FileName, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                            <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind StateText, Mode=OneWay}" />
                                            <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind StateDetail, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Click="MoveJobUpButton_Click" Content="Up" Tag="{x:Bind}" />
                                            <Button Click="MoveJobDownButton_Click" Content="Down" Tag="{x:Bind}" />
                                            <Button Click="RemoveJobButton_Click" Content="Remove" Tag="{x:Bind}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                    <Button Click="ImportFilesButton_Click" Content="Add MIDI" />
                    <Button Click="ClearQueueButton_Click" Content="Clear Queue" IsEnabled="{x:Bind ViewModel.CanClearQueue, Mode=OneWay}" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1" Margin="0,16,16,16">
            <StackPanel Spacing="18">
                <Border
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                    <StackPanel Spacing="16">
                        <StackPanel>
                            <TextBlock FontSize="30" FontWeight="SemiBold" Text="Sound Design" />
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Shape up to three waveform layers, preview them, then export the current queue as WAV." TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <TextBlock FontWeight="SemiBold" Text="Queued:" />
                            <TextBlock Text="{x:Bind ViewModel.QueueSummary, Mode=OneWay}" />
                            <TextBlock FontWeight="SemiBold" Text="Layers:" />
                            <TextBlock Text="{x:Bind ViewModel.LayerSummary, Mode=OneWay}" />
                            <TextBlock FontWeight="SemiBold" Text="Audible:" />
                            <TextBlock Text="{x:Bind ViewModel.AudibleLayerCount, Mode=OneWay}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <StackPanel>
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Layers" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Blend up to three waveforms with inline preview playback." />
                            </StackPanel>
                            <Button Click="AddLayerButton_Click" Content="Add Layer" HorizontalAlignment="Right" />
                        </StackPanel>

                        <ItemsControl ItemsSource="{x:Bind ViewModel.Layers, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:WaveLayerViewModel">
                                    <Border Margin="0,0,0,12" Padding="16" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="16">
                                        <StackPanel Spacing="12">
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="{x:Bind Title, Mode=OneWay}" />
                                                <Button Click="PreviewLayerButton_Click" Content="Preview" Tag="{x:Bind}" />
                                                <Button Click="RemoveLayerButton_Click" Content="Remove" IsEnabled="{x:Bind CanRemove, Mode=OneWay}" Tag="{x:Bind}" />
                                            </StackPanel>

                                            <ComboBox
                                                ItemsSource="{x:Bind WaveTypes, Mode=OneWay}"
                                                SelectedItem="{Binding Type, Mode=TwoWay}" />

                                            <StackPanel Visibility="{x:Bind IsPulse, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                                <TextBlock Text="{x:Bind DutyLabel, Mode=OneWay}" />
                                                <Slider Maximum="0.99" Minimum="0.01" StepFrequency="0.01" Value="{Binding Duty, Mode=TwoWay}" />
                                            </StackPanel>

                                            <StackPanel>
                                                <TextBlock Text="{x:Bind VolumeLabel, Mode=OneWay}" />
                                                <Slider Maximum="2" Minimum="0" StepFrequency="0.1" Value="{Binding Volume, Mode=TwoWay}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                    <StackPanel Spacing="16">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Output" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Choose the export sample rate. Output naming stays aligned with the existing apps." />
                        <ComboBox ItemsSource="{x:Bind ViewModel.SampleRates, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SampleRate, Mode=TwoWay}" />
                        <TextBlock Text="{x:Bind ViewModel.SampleRateTitle, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                    <StackPanel Spacing="12">
                        <ProgressRing IsActive="{x:Bind ViewModel.IsProcessing, Mode=OneWay}" />
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}" Text="{x:Bind ViewModel.LastErrorMessage, Mode=OneWay}" TextWrapping="WrapWholeWords" Visibility="{x:Bind ViewModel.HasError, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.LastRunSummary, Mode=OneWay}" TextWrapping="WrapWholeWords" Visibility="{x:Bind ViewModel.HasSummary, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                        <Button Click="ExportButton_Click" Content="{x:Bind ViewModel.ExportButtonTitle, Mode=OneWay}" IsEnabled="{x:Bind ViewModel.CanStartConversion, Mode=OneWay}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
